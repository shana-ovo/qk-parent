<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.qk.mapper.CourseMapper">
    <select id="getCourses" resultType="com.qk.entity.Course">
        select id, subject, name, price, target, description, create_time, update_time
        from course
        <where>
            <if test="name != null and name.length()>0">
                and name like concat('%',#{name},'%')
            </if>
            <if test="subject != null">
                and subject = #{subject}
            </if>
            <if test="target != null">
                and target = #{target}
            </if>
        </where>
    </select>
</mapper>